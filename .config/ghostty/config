# Ghostty Configuration
# Docs: https://ghostty.org/docs/config

# Font
font-family = JetBrains Mono
font-size = 14

# Theme (comment out to use default)
theme = Catppuccin Mocha

# Window
window-padding-x = 8
window-padding-y = 8

# Cmd+key shortcuts: terminal sends F-key escape sequences, tmux intercepts them.
# See README.md § Keyboard Shortcuts.
# Cmd+K  → F12 → clear screen
keybind = super+k=text:\x1b[24~
# Cmd+E  → F11 → workmux dashboard
keybind = super+e=text:\x1b[23~
# Cmd+L  → F10 → logger window
keybind = super+l=text:\x1b[21~
# (was: wt list — moved to Hammerflow Hyper+W+L)
# (Cmd+J was wt switch — moved to Cmd+Shift+R below as session picker)
# Cmd+;  → F8  → toggle last tmux window
keybind = super+semicolon=text:\x1b[19~
# Cmd+/  → F7  → scratch popup shell
keybind = super+slash=text:\x1b[18~
# Cmd+R  → reload ghostty config (tmux config auto-reloads via tmux-autoreload on save)
keybind = super+r=action:reload_config
# Cmd+T  → F2  → new tmux window
keybind = super+t=text:\x1b[12~
# Cmd+W      → F3       → kill tmux pane
keybind = super+w=text:\x1b[13~
# Cmd+Enter  → F4       → toggle pane zoom
keybind = super+enter=text:\x1b[14~
# Cmd+A      → F5       → ai window
keybind = super+a=text:\x1b[15~
# Cmd+N      → User0    → nvim window  (extended F-key range, bound via tmux user-keys)
keybind = super+n=text:\x1b[25~
# Cmd+S      → User1    → shell window
keybind = super+s=text:\x1b[26~
# --- Cmd+Shift+* → tmux session navigation (across-session namespace) ---
# Cmd+Shift+;  → User11 → toggle last session
# Cmd+Shift+R  → F9     → fzf session picker (reuses F9 slot)
# Cmd+Shift+D  → User12 → dotfiles session
# Cmd+Shift+N  → User13 → notes session
keybind = super+shift+semicolon=text:\x1b[39~
keybind = super+shift+r=text:\x1b[20~
keybind = super+shift+d=text:\x1b[40~
keybind = super+shift+n=text:\x1b[41~
keybind = super+shift+m=text:\x1b[42~

# Cmd+1..9   → User2..User10 → jump to tmux window N
keybind = super+1=text:\x1b[28~
keybind = super+2=text:\x1b[29~
keybind = super+3=text:\x1b[31~
keybind = super+4=text:\x1b[32~
keybind = super+5=text:\x1b[33~
keybind = super+6=text:\x1b[34~
keybind = super+7=text:\x1b[36~
keybind = super+8=text:\x1b[37~
keybind = super+9=text:\x1b[38~

# Disabled (custom workflow shortcuts; rebind in Hammerflow if you still want them):
# Cmd+Shift+D → F7 → cleanup worktrees   (now Cmd+/ scratch popup)
# Cmd+Shift+K → F6 → kill dev processes  (now Cmd+R reload tmux config)
# Cmd+Shift+P → F5 → list dev processes
# Cmd+Shift+R → F4 → start dev in session
# keybind = super+shift+d=text:\x1b[18~
# keybind = super+shift+k=text:\x1b[17~
# keybind = super+shift+p=text:\x1b[15~
# keybind = super+shift+r=text:\x1b[14~

# macOS-specific
macos-option-as-alt = true
