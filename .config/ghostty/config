# Ghostty Configuration
# Docs: https://ghostty.org/docs/config

# Font
font-family = JetBrains Mono
font-size = 14

# Theme (comment out to use default)
theme = Catppuccin Mocha

# Window
window-padding-x = 8
window-padding-y = 8

# Cmd+key shortcuts: terminal sends F-key escape sequences, tmux intercepts them.
# See README.md § Keyboard Shortcuts.
# Cmd+K  → F12 → clear screen
keybind = super+k=text:\x1b[24~
# Cmd+E  → F11 → workmux dashboard
keybind = super+e=text:\x1b[23~
# Cmd+L  → F10 → wt list (current project)
keybind = super+l=text:\x1b[21~
# Cmd+J  → F9  → wt switch (all projects)
keybind = super+j=text:\x1b[20~
# Cmd+;  → F8  → new Claude session
keybind = super+semicolon=text:\x1b[19~
# Cmd+Shift+D → F7 → cleanup worktrees
keybind = super+shift+d=text:\x1b[18~
# Cmd+Shift+K → F6 → kill dev processes
keybind = super+shift+k=text:\x1b[17~
# Cmd+Shift+P → F5 → list dev processes
keybind = super+shift+p=text:\x1b[15~
# Cmd+Shift+R → F4 → start dev in session
keybind = super+shift+r=text:\x1b[14~

# macOS-specific
macos-option-as-alt = true
