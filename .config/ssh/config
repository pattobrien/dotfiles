# General defaults
Host *
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    AddKeysToAgent yes
    UseKeychain yes
    ServerAliveInterval 60

# GitHub: auto-trust the host key on first connect (then pin it) so a fresh
# machine doesn't fail host-key verification on the first SSH push/pull.
Host github.com
    StrictHostKeyChecking accept-new


