[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[user]
	name = pattobrien
	email = 12474318+pattobrien@users.noreply.github.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINlKkfz5It5hj2VIVsEZaYl8PCcW6DIkWLCG7ivCGThB
[init]
	defaultBranch = main
[core]
	editor = code --wait
[http]
	postBuffer = 100000000
# Route all GitHub traffic over HTTPS, rewriting any ssh-style git@github.com:
# remotes to https. Public clones (e.g. lazy.nvim) and pushes then work on a
# fresh machine without an SSH key configured.
[url "https://github.com/"]
	insteadOf = git@github.com:
# Authenticate HTTPS pushes/pulls with the gh CLI's stored token (`gh auth
# login`); this overrides the system osxkeychain helper for github.com.
[credential "https://github.com"]
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = !gh auth git-credential
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[alias]
	wt = "!f() { root=\"$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir)\")\"; git fetch origin && git worktree add --no-track \"$root/.worktrees/$1\" -b \"patt/$1\" origin/main; }; f"
