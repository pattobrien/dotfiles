#!/usr/bin/env bash

set -e

# brew bundle installs entries via a parallel thread pool by default
# (HOMEBREW_BUNDLE_JOBS=auto). Concurrent `code --install-extension` processes
# race and corrupt VS Code's extensions.json (microsoft/vscode#238639), which
# cascades into mass VS Code extension install failures. Serialize installs.
export HOMEBREW_BUNDLE_NO_JOBS=1

PROFILE=$1
BREWFILE="${PROFILE:+$PROFILE/}Brewfile"
CONFIG="install${PROFILE:+.$PROFILE}.conf.yaml"

if [ -z "$PROFILE" ]; then
    echo "No profile specified, using default"
else
    shift # remove the first argument
fi

DOTBOT_DIR="dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"

