{
  "runtime": {
    "version": "Lua 5.4"
  },
  "workspace": {
    "library": [
      "${3rd}/luassert/library",
      "~/.hammerspoon/Spoons/EmmyLua.spoon/annotations"
    ],
    "ignoreDir": [".config/hammerspoon/Spoons"]
  },
  "diagnostics": {
    "globals": ["vim"],
    "ignoredFiles": "Disable",
    "libraryFiles": "Disable",
    "disable": ["inject-field"]
  }
}
