    "\"typescript\"": "\"typescript\""
  },
  "[jsonc]": {
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 120,
    "editor.rulers": [
      120
    ]
  },
  "yaml.schemas": {
    "https://json.schemastore.org/dart-build.json": "build.yaml",
