  "neonLocal.port": 5432,
  "githubLocalActions.dockerDesktopPath": "/Applications/Docker.app",
  "filewatcher.commands": [
    {
      "match": ".*\\.tsx?$",
      "event": "onFileRename",
      "vscodeTask": "typescript.restartTsServer",
      "isAsync": true
    },
    {
      "match": ".*\\.tsx?$",
      "event": "onFileDelete",
      "vscodeTask": "typescript.restartTsServer",
      "isAsync": true
    },
    {
      "match": ".*",
