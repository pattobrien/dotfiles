#!/bin/sh
# Jump to the first tmux window with the given name in the current session.
# Shows a tmux status message if no match exists. Picks the first match when
# multiple windows share a name (since `:=NAME` errors on duplicates).
# Usage: tmux-jump <window-name>
TMUX_BIN=/opt/homebrew/bin/tmux

name="$1"

if [ -z "$name" ]; then
  echo "Usage: tmux-jump <window-name>" >&2
  exit 1
fi

target=$($TMUX_BIN list-windows -F '#{window_id}|#{window_name}' \
  | awk -F'|' -v n="$name" '$2 == n {print $1; exit}')

if [ -n "$target" ]; then
  $TMUX_BIN select-window -t "$target"
else
  $TMUX_BIN display-message "no window named '$name'"
fi
