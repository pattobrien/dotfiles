#!/bin/zsh

export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# Determine Homebrew prefix once (used throughout this file)
if [[ -d "/opt/homebrew" ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"
else
    HOMEBREW_PREFIX="/usr/local"
fi

# 1Password SSH Agent
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"


# NOTE: the below script is always causing vscode to crash on startup, 
# because the shell that vscode initializes on startup is NOT the same as the
# vscode terminal shell (i.e. TERM_PROGRAM is NOT 'vscode')
# # initialize tmux if it's not already running in the current shell
# # NOTE: this must be initialized before p10k is initialized
# DOES_TMUX_EXIST=$(tmux ls 2>/dev/null)
# if [ "$TERM_PROGRAM" != "vscode" ] && [ -z "$TMUX" ] && [ -z "$DOES_TMUX_EXIST" ]; then
#   exec tmux new-session -A -s workspace
# fi


# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh" # Path to your oh-my-zsh installation.
source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# ZSH_THEME="powerlevel10k/powerlevel10k"

# Below are miscellaneous OH MY ZSH settings that could be useful
# CASE_SENSITIVE="true" # case-sensitive completion.
# ENABLE_CORRECTION="true" # command auto-correction.
# DISABLE_UNTRACKED_FILES_DIRTY="true"

# ZSH plugins
plugins=(
  fzf-tab # must be before other completion plugins
  git
  # zsh-autosuggestions
  # zsh-syntax-highlighting
  zsh-interactive-cd

  # untested plugins below:
  1password
  gh
  keychain
  kubectl
  minikube
  kind
  helm
  kubectx
  skaffold # autocompletion
  terraform # aliases and autocompletion
  fzf
  github
  vscode
  xcode
  tmux
  # dotenv # - source .env variables when you cd into a directory
  gitignore
  # asdf # replaced by mise
  mise
  # doctl # this causes 1password prompt when re-sourcing zshrc file, for some reason... so we should not use this
  # pnpm-shell-completion
  zsh-pnpm-completions
  # other plugins available that we should install at some point:
  # web-search
  # vi-mode
  # nvm
  # npm
  macos
  # tmuxinator (?)
  # aliases # lists the shortcuts currently available
  # common-aliases
  flutter # aliases for flutter commands
  # gcloud
  # git-auto-fetch
  # git-lfs
  # mongocli
  # operator-sdk
  pod # cocoaPods completion
  redis-cli
  # salt
  # ssh-agent # configure ssh-agent settings
  # web-search
)

# Disable oh-my-zsh auto-update prompts (run `omz update` manually instead)
DISABLE_AUTO_UPDATE=true

# enable zsh completions from homebrew (note: must be done before oh-my-zsh.sh is sourced)
PATH="$HOMEBREW_PREFIX/share/zsh/site-functions:${PATH}"
FPATH="$HOMEBREW_PREFIX/share/zsh/site-functions:${FPATH}"

# Docker CLI completions (must be before oh-my-zsh.sh so compinit picks them up in one pass)
fpath=(/Users/pattobrien/.docker/completions $fpath)

source $ZSH/oh-my-zsh.sh

# fzf: Catppuccin Mocha theme (matches kitty theme)
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
--color=selected-bg:#45475a \
--color=border:#6C7086,label:#CDD6F4"

# fzf-tab: use FZF_DEFAULT_OPTS (includes Catppuccin theme above)
zstyle ':fzf-tab:*' use-fzf-default-opts yes
# fzf-tab: accept focused item with tab instead of cycling
zstyle ':fzf-tab:*' fzf-bindings 'tab:accept'

# fzf-git.sh: rich git pickers via Ctrl-G chords (Ctrl-G Ctrl-B for branches, etc.)
source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/fzf-git.sh/fzf-git.sh

# User configuration

# export MANPATH="/usr/local/man:$MANPATH"

# Use nvim as default editor in terminal (kitty/tmux)
export EDITOR='nvim'

# Set personal aliases, overriding those provided by oh-my-zsh
# For a full list of active aliases, run `alias`.
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh  
source $HOMEBREW_PREFIX/share/powerlevel10k/powerlevel10k.zsh-theme

export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Initialize Homebrew environment (HOMEBREW_PREFIX set at top of file)
eval "$(${HOMEBREW_PREFIX}/bin/brew shellenv)"

export PATH="$HOMEBREW_PREFIX/bin:$PATH"

# MISC PATHS
export KUBE_CONFIG_PATH="$HOME/.kube/config"

PATH=$PATH:~/.local/bin

# mise is activated via oh-my-zsh plugin
# Add mise shims to PATH for stable executable paths (e.g. ~/.local/share/mise/shims/oxfmt)
export PATH="$HOME/.local/share/mise/shims:$PATH"

# source <(railway completion zsh)

source ~/.dotfiles/zsh/python.zsh
source ~/.dotfiles/zsh/credentials.zsh
source ~/.dotfiles/zsh/flutter.zsh
source ~/.dotfiles/zsh/aliases.zsh
source ~/.dotfiles/zsh/go.zsh
source ~/.dotfiles/zsh/php.zsh
source ~/.dotfiles/zsh/ruby.zsh
source ~/.dotfiles/zsh/completion-for-pnpm.zsh
source ~/.dotfiles/zsh/completion-for-workmux.zsh
_zsh_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
if [[ ! -f "$_zsh_cache_dir/wt_completions.zsh" ]] && command -v wt &>/dev/null; then
  mkdir -p "$_zsh_cache_dir"
  wt --completions-zsh >| "$_zsh_cache_dir/wt_completions.zsh" 2>/dev/null
fi
[[ -f "$_zsh_cache_dir/wt_completions.zsh" ]] && source "$_zsh_cache_dir/wt_completions.zsh"

if [ -f ~/.dotfiles/zsh/.env.zsh ]; then
  source ~/.dotfiles/zsh/.env.zsh
fi

bindkey -v # set up vim motions in interactive terminal

# Cmd+K (via Ghostty F12 escape sequence): clear screen + scrollback when not in tmux
# Inside tmux this is handled by tmux's F12 binding in .tmux.conf
if [[ -z "$TMUX" ]]; then
  function _clear-screen-and-scrollback() {
    clear && printf '\e[3J'
    zle reset-prompt
  }
  zle -N _clear-screen-and-scrollback
  bindkey '\e[24~' _clear-screen-and-scrollback
fi

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac


# alias exa='exa -laFh --git --icons'
# alias ls='exa'


## [Completion]
## Completion scripts setup. Remove the following line to uninstall
[[ -f /Users/pattobrien/.dart-cli-completion/zsh-config.zsh ]] && . /Users/pattobrien/.dart-cli-completion/zsh-config.zsh || true
## [/Completion]


# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/pattobrien/.cache/lm-studio/bin"
# End of LM Studio CLI section


# bun completions
[ -s "/Users/pattobrien/.bun/_bun" ] && source "/Users/pattobrien/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
#compdef neon
###-begin-neon-completions-###
#
# yargs command completion script
#
# Installation: neon completion >> ~/.zshrc
#    or neon completion >> ~/.zprofile on OSX.
#
_neon_yargs_completions()
{
  local reply
  local si=$IFS
  IFS=$'
' reply=($(COMP_CWORD="$((CURRENT-1))" COMP_LINE="$BUFFER" COMP_POINT="$CURSOR" neon --get-yargs-completions "${words[@]}"))
  IFS=$si
  _describe 'values' reply
}
compdef _neon_yargs_completions neon
###-end-neon-completions-###

# linear completions
if [[ ! -f "$_zsh_cache_dir/linear_completions.zsh" ]]; then
  mkdir -p "$_zsh_cache_dir"
  linear completions zsh >| "$_zsh_cache_dir/linear_completions.zsh" 2>/dev/null
fi
source "$_zsh_cache_dir/linear_completions.zsh"
export LINEAR_ISSUE_SORT="priority"
export LINEAR_VCS="git"
export LINEAR_TEAM_ID="ENG"
export LINEAR_WORKSPACE="getdots"


# maestro-runner
export PATH="$HOME/.maestro-runner/bin:$PATH"
