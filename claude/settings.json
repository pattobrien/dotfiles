{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "DISABLE_AUTOUPDATER": "0",
    "EDITOR": "cursor",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "cleanupPeriodDays": "365",
    "CLAUDE_CODE_NO_FLICKER": "0"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(pnpm* build*)",
      "Bash(pnpm* format*)",
      "Bash(pnpm* install)",
      "Bash(pnpm* knip*)",
      "Bash(pnpm* lint*)",
      "Bash(pnpm* list*)",
      "Bash(pnpm* outdated:*)",
      "Bash(pnpm* remove*)",
      "Bash(pnpm* run*)",
      "Bash(pnpm* start*)",
      "Bash(pnpm* typecheck*)",
      "Bash(pnpm* test*)",
      "Bash(pnpm* validate*)",
      "Bash(pnpm* view*)",
      "Bash(pnpm* why*)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(bat *)",
      "Bash(cat *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(for *)",
      "Bash(fzf *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(xargs *)",
      "Bash(wc *)",
      "Bash(yq *)",
      "Bash(brew *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git mv *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git status *)",
      "Bash(git worktree *)",
      "Bash(git diff-branch *)",
      "Bash(git diff-commit *)",
      "Bash(git diff-files *)",
      "Bash(git diff-index *)",
      "Bash(git diff-tag *)",
      "Bash(git diff-remote *)",
      "Bash(git diff-stash *)",
      "Bash(git diff-tree *)",
      "Bash(git diff-worktree *)",
      "Bash(gh api *)",
      "Bash(gh issue *)",
      "Bash(gh list *)",
      "Bash(gh pr *)",
      "Bash(gh release *)",
      "Bash(gh view *)",
      "Bash(docker *)",
      "Bash(linear issue *)",
      "Bash(defaults read *)",
      "mcp__expo-mcp__*",
      "mcp__plugin_figma_figma__*",
      "mcp__plugin_figma_figma-desktop__*",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:unpkg.com)"
    ],
    "deny": [
      "Bash(npm *)",
      "Bash(npx *)",
      "mcp__ide__getDiagnostics"
    ],
    "ask": [
      "Bash(pnpm* add *)",
      "Bash(brew install *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-opus-4-6[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status waiting"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": [],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status done"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'input=$(cat); model=$(echo \"$input\" | jq -r \".model.display_name\"); total_in=$(echo \"$input\" | jq -r \".context_window.total_input_tokens\"); total_out=$(echo \"$input\" | jq -r \".context_window.total_output_tokens\"); total=$((total_in + total_out)); if [ $total -ge 1000000 ]; then tokens=$(printf \"%.1fM\" $(echo \"scale=1; $total / 1000000\" | bc)); elif [ $total -ge 1000 ]; then tokens=$(printf \"%.1fK\" $(echo \"scale=1; $total / 1000\" | bc)); else tokens=\"$total\"; fi; usage=$(echo \"$input\" | jq \".context_window.current_usage\"); if [ \"$usage\" != \"null\" ]; then current=$(echo \"$usage\" | jq \".input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens\"); size=$(echo \"$input\" | jq \".context_window.context_window_size\"); pct=$((current * 100 / size)); context=\"${pct}%\"; else context=\"0%\"; fi; printf \"\\033[36m%s\\033[0m | \\033[33m%s tokens\\033[0m | \\033[35m%s context\\033[0m\" \"$model\" \"$tokens\" \"$context\"'"
  },
  "enabledPlugins": {
    "claude-notifications-go@claude-notifications-go": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "expo-app-design@expo-plugins": true,
    "figma@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "slack@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "neon@meagain": true,
    "meagain@meagain": true,
    "posthog@meagain": true,
    "revenuecat@meagain": true,
    "sentry@meagain": true,
    "stripe@meagain": true,
    "vercel@meagain": false,
    "github@meagain": true,
    "skill-creator@claude-plugins-official": true,
    "oxlint-lsp@meagain": false,
    "tsgo-lsp@meagain": false,
    "figma-desktop@meagain": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "expo-plugins": {
      "source": {
        "source": "github",
        "repo": "expo/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "stable",
  "plansDirectory": "./docs/plans",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
