{
  "name": "dotfiles-scripts",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "A simple example library built by tsdown",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp lib",
    "dev": "vp lib --watch",
    "lint": "vp lint",
    "lint:fix": "vp lint --write",
    "format": "vp fmt --check",
    "format:fix": "vp fmt --write",
    "check": "vp check"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "picocolors": "^1.1.1",
    "simple-git": "^3.32.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260309.1",
    "oxlint": "^1.51.0",
    "vite-plus": "latest"
  }
}
